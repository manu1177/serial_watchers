{% extends 'base.html.twig' %}

{% block title %}
	{{movie.title}}
{% endblock %}

{% block body %}
	<div class="container bg-dark rounded-4 p-5 my-5">
		<h1 class="text-center text-white mb-5">{{movie.title}}</h1>
		<div class="row">
			<div class="card p-3">
				<div class="d-flex justify-content-between">
					<p>{{ movie.releaseYear }}</p>
					<p>{{ movie.genre }}</p>
				</div>
				<p>Synopsis :
					{{ movie.synopsis }}</p>


				<a href="{{ path('app_director_detail', {id: movie.director.id}) }}" class="btn btn-primary mt-5 w-25 mx-auto">{{movie.director.lastName}}</a>
			</div>
		</div>

	</div>
{% endblock %}
